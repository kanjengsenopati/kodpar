# Koperasi Backend Configuration
PORT=3001

# NeonDB Connection String
# Get this from your Neon Console (Dashboard -> Connection Details)
# Example: postgres://username:password@ep-host-id.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://YOUR_USERNAME:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require
